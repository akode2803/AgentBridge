{
  "id": "claude",
  "label": "Claude Code",
  "command": "claude",
  "args": ["-p", "{prompt}", "--output-format", "stream-json", "--verbose",
           "--max-turns", "60"],
  "args_minimal": ["-p", "{prompt}", "--output-format", "stream-json",
                   "--verbose"],
  "permission_args": ["--mcp-config", "{mcp_config}",
                      "--permission-prompt-tool", "mcp__ab__approve",
                      "--allowedTools", "mcp__ab"],
  "auto_allow": ["Read", "Glob", "Grep", "TodoWrite"],
  "model_args": ["--model", "{model}"],
  "effort_args": ["--effort", "{effort}"],
  "efforts": ["low", "medium", "high", "xhigh", "max"],
  "blocklist_args": ["--disallowedTools", "{tool}"],
  "blocklist": ["Bash", "WebFetch", "WebSearch", "Task", "Agent",
                "NotebookEdit", "KillShell"],
  "aux_web": ["WebFetch", "WebSearch"],
  "format": "claude-stream",
  "models": ["claude-fable-5", "claude-opus-4-8", "claude-sonnet-5",
             "claude-haiku-4-5-20251001"],
  "verified": true
}
